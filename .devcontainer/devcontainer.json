{
  "name": "AIMAG AI Terminal",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [3000, 8000, 5432, 6379],
  "portsAttributes": {
    "3000": { "label": "Frontend (Next.js)" },
    "8000": { "label": "Backend (FastAPI)" },
    "5432": { "label": "Postgres" },
    "6379": { "label": "Redis" }
  },
  // Runs once when the codespace/container is first created: installs
  // dependencies and creates .env files from the .example templates if
  // they don't exist yet (never overwrites an existing .env).
  "postCreateCommand": "bash scripts/devcontainer-setup.sh",
  // Runs every time the container (re)starts, including resuming a
  // stopped codespace: brings Postgres/Redis back up. Idempotent and
  // safe to run repeatedly.
  "postStartCommand": "bash scripts/dev-infra.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
