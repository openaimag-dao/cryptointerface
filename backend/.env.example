ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Database (async SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://aimag:aimag@localhost:5432/aimag

# Redis cache
REDIS_URL=redis://localhost:6379/0

# Binance USDT-M Futures endpoints (public market data only — no account access)
BINANCE_REST_BASE_URL=https://fapi.binance.com
BINANCE_WS_BASE_URL=wss://fstream.binance.com
# Only needed for private/account endpoints, not used by the public Data Engine yet.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# CoinGecko — public spot-market fallback used only when Binance is unreachable.
# See backend/README.md's "CoinGecko fallback" section.
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Data engine
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,DOGEUSDT,BNBUSDT,XRPUSDT
TIMEFRAMES=1m,5m,15m,1h,4h,1d
HISTORICAL_CANDLES_PER_TIMEFRAME=5000
WS_RECONNECT_MIN_DELAY_SECONDS=1
WS_RECONNECT_MAX_DELAY_SECONDS=60
WS_HEARTBEAT_INTERVAL_SECONDS=30

# AI Chat — Anthropic Claude API key for the chat assistant only (the AI
# Decision Engine stays deterministic/no-LLM). Get one at
# https://console.anthropic.com/. Leave blank to disable AI Chat (the
# endpoint replies with a "not configured" message instead of erroring).
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-5

# Sprint 4: Intelligence Layer (app/intelligence/). Alpha Vantage free
# tier is 25 requests/day — get a key at
# https://www.alphavantage.co/support/#api-key. Leave blank to disable
# the 7 ETF/treasury-proxied macro indicators; Fear & Greed and BTC
# Dominance stay free/keyless regardless. See backend/README.md's
# "Intelligence Layer" section.
ALPHA_VANTAGE_API_KEY=
MACRO_POLL_INTERVAL_SECONDS=21600
NEWS_POLL_INTERVAL_SECONDS=600
SENTIMENT_RECOMPUTE_INTERVAL_SECONDS=300
LLM_EXPLANATION_INTERVAL_SECONDS=1800
LLM_EXPLANATION_ANCHOR_SYMBOL=BTCUSDT

# Whale Engine — Etherscan free-tier API key, get one at
# https://etherscan.io/apis. Leave blank to disable (the poller no-ops,
# same fail-open pattern as every other Sprint 4 provider).
ETHERSCAN_API_KEY=
WHALE_POLL_INTERVAL_SECONDS=300
WHALE_MIN_USD_THRESHOLD=250000
